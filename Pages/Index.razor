@page "/"
@using Shard.Components.Shards
@using Shard.Data
@inject GlobalData Data;
@inject IDialogService DialogService;
@inject NavigationManager Manager;
@inject FileService FileService;

<PageTitle>Shards</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Добро пожаловать в Shard</MudText>
@if (Data.ActiveShard != null)
{
    <MudText Typo="Typo.h6" GutterBottom="true">Активный Shard файл
        <MudChip T="string" Color="Color.Primary">@Data.ActiveShard</MudChip>
    </MudText>
}
else
{
    <MudText Class="mb-8">Для начала работы выберите Shard файл</MudText>
}

<MudButton @onclick="CreateShard" Color="Color.Primary" Variant="Variant.Filled" DropShadow="false">Создать новый
</MudButton>
<br/>
<br/>
<MudText Typo="Typo.h6" GutterBottom="true">Файлов в медиатке</MudText>
<MudGrid Spacing="2" Justify="Justify.FlexStart">
    @foreach (var score in _scores)
    {
        <MudItem>
            <MudCard>
                <MudCardContent>
                    <MudText Typo="Typo.h5">@score.Key</MudText>
                    <MudText Typo="Typo.body2">@score.Value</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    private List<KeyValuePair<string, int>> _scores = [];

    private async Task CreateShard()
    {
        var dialog = DialogService.Show<CreateShardDialog>("Новый Shard файл");
        var result = await dialog.Result;

        if (!result.Cancelled && result.Data != null)
        {
            Data.CreateShard(result.Data.ToString()!);
            Manager.Refresh();
        }
    }

    protected override void OnInitialized()
    {
        _scores = FileService.GetScores();
    }

}