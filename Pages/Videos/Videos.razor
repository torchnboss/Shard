@page "/Videos"
@using Shard.Data
@using Shard.Components.Videos
@inject GlobalData Data;
@inject FileService FileService;
@inject FolderService FolderService;
@inject NavigationManager Manager;

<PageTitle>Мои Видосы</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Мои Видосы
    <MudIconButton @onclick="GoSettings" Icon="@Icons.Material.Filled.Settings"
                   aria-label="settings"/>
</MudText>
@if (Data.ActiveShard != null)
{
    <MudTextField Style="width: 100%" @bind-Value="_search" T="string" Variant="Variant.Outlined"
                  Label="Поиск по видосам"></MudTextField>
    <br/>
    @foreach (var folder in _folders)
    {
        <MudChip T="string" @onclick="() => _search = folder.Path" Color="Color.Primary">@folder.Name</MudChip>
    }

    <br/>
    <br/>
    <MudSwitch T="bool" @bind-Checked="_captionOnly" Label="Только с подписью" Color="Color.Primary"/>
    <br/>
    <br/>
    <MudGrid Spacing="2" Justify="Justify.Center">
        @foreach (var file in FilteredFiles)
        {
            <MudItem>
                <VideoCard Vid="file"/>
            </MudItem>
        }
    </MudGrid>
}
else
{
    <MudText Class="mb-8">Для начала работы выберите Shard файл</MudText>
}

@code {

    private bool _captionOnly;
    private string _search = "";
    private List<MediaFile> _videos = [];
    private List<Folder> _folders = [];

    private IEnumerable<MediaFile> FilteredFiles =>
        _videos
            .Where(x =>
            {
                if (_captionOnly && string.IsNullOrEmpty(x.Caption)) return false;
                if (string.IsNullOrEmpty(_search)) return true;
                if (_search.Contains("\\"))
                    return Path.GetDirectoryName(x.Path) == _search;
                var search = _search.ToLower();
                if (!string.IsNullOrEmpty(x.Caption) && x.Caption.ToLower().Contains(search))
                    return true;
                return x.Name.ToLower().Contains(search);
            });

    private void GoSettings()
    {
        Manager.NavigateTo("Videos/Settings");
    }

    protected override void OnInitialized()
    {
        _videos = FileService.GetFiles(FolderType.Videos);
        _folders = FolderService.GetFolders(FolderType.Videos);
    }

}
