@using Shard.Data

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Videocam" Class="mr-3 mb-n1"/>
            Видос @Vid.Name
        </MudText>
    </TitleContent>
    <DialogContent>
        <iframe style="width: 1280px; height: 720px; margin-left: -320px" src="@Vid.GetVideoPath()"></iframe>
        <MudTextField Variant="Variant.Outlined" @bind-Value="_caption" Label="Подпись"/>
        <MudSwitch T="bool" @bind-Checked="_isSpoiler" Label="Спойлер" Color="Color.Info" />
    </DialogContent>
    <DialogActions>
        <MudButton Class="mb-4" Color="Color.Primary" Variant="Variant.Filled" @onclick="SavePic">Сохранить</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public MediaFile Vid { get; set; } = null!;

    private bool _isSpoiler;
    private string? _caption;
    
    protected override void OnInitialized()
    {
        _caption = Vid.Caption;
        _isSpoiler = Vid.IsSpoiler;
    }
    
    private void SavePic()
    {
        Vid.IsSpoiler = _isSpoiler;
        Vid.Caption = _caption;
        MudDialog.Close(DialogResult.Ok(true));
    }
}