<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            Создать новый Shard файл
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField Variant="Variant.Outlined" @bind-Value="ShardName" Label="Имя Shard файла"/>
    </DialogContent>
    <DialogActions>
        <MudButton Class="mb-4" Color="Color.Primary" Variant="Variant.Filled" @onclick="SaveShard">Создать</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public string ShardName { get; set; } = null!;

    private void SaveShard()
    {
        MudDialog.Close(DialogResult.Ok(ShardName));
    }
}